// MysticNameTags Dashboard UI
// Uses real Hytale TabNavigation with tabs attached to the main panel

$C = "../Common.ui";

// ===================== SHARED STYLES =====================
@TitleStyle = LabelStyle(
  FontSize: 18,
  RenderUppercase: true,
  RenderBold: true,
  TextColor: #f0b429,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@SectionTitle = LabelStyle(
  FontSize: 12,
  RenderBold: true,
  RenderUppercase: true,
  TextColor: #b0b8c0
);

@StatLabel = LabelStyle(
  FontSize: 11,
  TextColor: #8b949e,
  VerticalAlignment: Center
);

@StatValue = LabelStyle(
  FontSize: 12,
  TextColor: #e6edf3,
  RenderBold: true,
  VerticalAlignment: Center
);

@MutedLabel = LabelStyle(
  FontSize: 11,
  TextColor: #7d8da3,
  VerticalAlignment: Center
);

@BodyLine = LabelStyle(
  FontSize: 12,
  TextColor: #c9d1d9,
  Wrap: true
);

@BodyLineMuted = LabelStyle(
  FontSize: 12,
  TextColor: #96a9be,
  Wrap: true
);

@PanelHeaderStyle = LabelStyle(
  FontSize: 13,
  TextColor: #ffffff,
  RenderBold: true,
  VerticalAlignment: Center
);

@PrimaryButton = TextButtonStyle(
  Default: (
    Background: (Color: #3a7bd5),
    LabelStyle: (
      FontSize: 13,
      TextColor: #ffffff,
      RenderBold: true,
      HorizontalAlignment: Center,
      VerticalAlignment: Center
    )
  ),
  Hovered: (
    Background: (Color: #4a8be5),
    LabelStyle: (
      FontSize: 13,
      TextColor: #ffffff,
      RenderBold: true,
      HorizontalAlignment: Center,
      VerticalAlignment: Center
    )
  ),
  Pressed: (
    Background: (Color: #2a6bc5),
    LabelStyle: (
      FontSize: 13,
      TextColor: #ffffff,
      RenderBold: true,
      HorizontalAlignment: Center,
      VerticalAlignment: Center
    )
  )
);

@SecondaryButton = TextButtonStyle(
  Default: (
    Background: (Color: #2b3542),
    LabelStyle: (
      FontSize: 13,
      TextColor: #96a9be,
      RenderBold: true,
      HorizontalAlignment: Center,
      VerticalAlignment: Center
    )
  ),
  Hovered: (
    Background: (Color: #3b4552),
    LabelStyle: (
      FontSize: 13,
      TextColor: #b6c9de,
      RenderBold: true,
      HorizontalAlignment: Center,
      VerticalAlignment: Center
    )
  ),
  Pressed: (
    Background: (Color: #1b2532),
    LabelStyle: (
      FontSize: 13,
      TextColor: #d0d8e4,
      RenderBold: true,
      HorizontalAlignment: Center,
      VerticalAlignment: Center
    )
  )
);

// ===================== PAGE =====================
$C.@PageOverlay {
  LayoutMode: Top;

  SceneBlur #SceneBlur1 {}
  SceneBlur #SceneBlur2 {}

  Group {
    LayoutMode: Middle;
    FlexWeight: 1;

    Group #MainContent {
      Anchor: (Width: 1380, Height: 950);
      Background: (Color: #101010(0.78));
      OutlineColor: #2f2f2f;
      OutlineSize: 3;
      LayoutMode: Top;
      Padding: (Top: 18, Bottom: 18, Left: 20, Right: 20);

      // ===================== TITLE =====================
      Group {
        Anchor: (Height: 52, Bottom: 8);
        LayoutMode: Middle;

        Group {
          Anchor: (Width: 320, Height: 34);
          Background: (TexturePath: "../Common/PopupTitle.png", HorizontalBorder: 50, VerticalBorder: 0);
          LayoutMode: Center;
          Padding: (Top: 4);

          Label #TitleLabel {
            Style: @TitleStyle;
            Text: "DASHBOARD";
          }
        }
      }

      // ===================== WORKSPACE =====================
      Group #DashboardWorkspace {
        FlexWeight: 1;
        LayoutMode: Left;
        Padding: (Top: 8);

        // ===================== LEFT COLUMN =====================
        Group #SummaryColumn {
          Anchor: (Width: 350, Right: 24);
          LayoutMode: Top;

          Group {
            Anchor: (Height: 340, Bottom: 18);
            Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
            Padding: (Full: 14);
            LayoutMode: Top;

            Group {
              Anchor: (Height: 8, Bottom: 10);
              Background: (TexturePath: "../Pages/Portals/PortalTopDivider.png");
            }

            Label {
              Text: "SUMMARY";
              Style: @SectionTitle;
              Anchor: (Height: 18, Bottom: 8);
            }

            Label #StatusText {
              Text: "Welcome to MysticNameTags!";
              Anchor: (Height: 22, Bottom: 10);
              Style: (FontSize: 14, TextColor: #c6d6e7);
            }

            Group {
              Anchor: (Height: 1, Bottom: 10);
              Background: (Color: #2b3542);
            }

            Label #VersionLabel { Text: "Version: dev"; Anchor: (Height: 22); Style: @StatValue; }
            Label #IntegrationsLabel { Text: "Integrations: (detecting...)"; Anchor: (Height: 22); Style: @StatValue; }
            Label #TagCountLabel { Text: "Loaded Tags: 0"; Anchor: (Height: 22); Style: @StatValue; }
            Label #StorageLabel { Text: "Storage: File"; Anchor: (Height: 22); Style: @StatValue; }
            Label #PlaceholderBackendsLabel { Text: "Placeholders: none"; Anchor: (Height: 22, Bottom: 10); Style: @StatValue; }

            Group {
              Anchor: (Height: 1, Bottom: 10);
              Background: (Color: #2b3542);
            }

            Label #CpuLabel { Text: "CPU (process): N/A"; Anchor: (Height: 20); Style: @MutedLabel; }
            Label #RamLabel { Text: "RAM (JVM): N/A"; Anchor: (Height: 20); Style: @MutedLabel; }
            Label #UptimeLabel { Text: "Uptime: N/A"; Anchor: (Height: 20); Style: @MutedLabel; }
          }

          Group {
            FlexWeight: 1;
            Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
            Padding: (Full: 14);
            LayoutMode: Top;

            Group {
              Anchor: (Height: 8, Bottom: 10);
              Background: (TexturePath: "../Pages/Portals/PortalTopDivider.png");
            }

            Label #QuickActionsHeader {
              Text: "QUICK ACTIONS";
              Style: @SectionTitle;
              Anchor: (Height: 18, Bottom: 12);
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 46, Bottom: 10);

              TextButton #OpenTagsButton {
                Text: "Open Tag UI";
                FlexWeight: 1;
                Anchor: (Height: 40);
                Style: @SecondaryButton;
              }

              Group { Anchor: (Width: 10); }

              TextButton #ClearCacheButton {
                Text: "Clear Cache";
                FlexWeight: 1;
                Anchor: (Height: 40);
                Style: @SecondaryButton;
              }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 46, Bottom: 10);

              TextButton #RefreshNameplateButton {
                Text: "Refresh Nameplate";
                FlexWeight: 1;
                Anchor: (Height: 40);
                Style: @SecondaryButton;
              }

              Group { Anchor: (Width: 10); }

              TextButton #DebugSnapshotButton {
                Text: "Debug Snapshot";
                FlexWeight: 1;
                Anchor: (Height: 40);
                Style: @SecondaryButton;
              }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 46, Bottom: 10);

              TextButton #RefreshButton {
                Text: "Refresh";
                FlexWeight: 1;
                Anchor: (Height: 40);
                Style: @PrimaryButton;
              }

              Group { Anchor: (Width: 10); }

              TextButton #ReloadButton {
                Text: "Reload";
                FlexWeight: 1;
                Anchor: (Height: 40);
                Style: @SecondaryButton;
              }
            }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 46);

              TextButton #ModPageButton {
                Text: "Mod Page";
                FlexWeight: 1;
                Anchor: (Height: 40);
                Style: @SecondaryButton;
              }

              Group { Anchor: (Width: 10); }

              TextButton #BugReportButton {
                Text: "Report Bug";
                FlexWeight: 1;
                Anchor: (Height: 40);
                Style: @SecondaryButton;
              }
            }
          }
        }

        // ===================== RIGHT MAIN PANEL =====================
        Group #MainPanelColumn {
          FlexWeight: 1;
          LayoutMode: Top;

          Group #TabsRow {
            Anchor: (Height: 66, Bottom: 0);
            LayoutMode: Left;
            Padding: (Left: 18, Right: 18);

            TabNavigation #DashboardTabs {
              Anchor: (Height: 66, Width: 820);
              Style: $C.@TopTabsStyle;
              SelectedTab: "Overview";

              TabButton #OverviewTabButton {
                Icon: "../Common/RecipesIcon.png";
                TooltipText: "Overview";
                Id: "Overview";
              }

              TabButton #IntegrationsTabButton {
                Icon: "../Common/RecipesIcon.png";
                TooltipText: "Integrations";
                Id: "Integrations";
              }

              TabButton #DebugTabButton {
                Icon: "../Common/RecipesIcon.png";
                TooltipText: "Debug & Support";
                Id: "Debug";
              }

              TabButton #SupportTabButton {
                Icon: "../Common/RecipesIcon.png";
                TooltipText: "Support";
                Id: "Support";
              }
            }
          }

          Group #ContentColumn {
            FlexWeight: 1;
            LayoutMode: Top;
            Anchor: (Top: -6);

            Group {
              Anchor: (Height: 52, Bottom: 10);
              Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
              Padding: (Left: 18, Right: 18, Top: 10, Bottom: 10);
              LayoutMode: Left;

              Label #ActiveTabTitle {
                Text: "Overview";
                Style: @PanelHeaderStyle;
                FlexWeight: 1;
              }

              Label #MainCloseHint {
                Text: "Press ESC to close";
                Style: @MutedLabel;
                Anchor: (Width: 140, Height: 18, Vertical: 0);
              }
            }

            Group #TabContentContainer {
              FlexWeight: 1;
              Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
              Padding: (Full: 16);
              LayoutMode: Top;

              Group {
                Anchor: (Height: 8, Bottom: 10);
                Background: (TexturePath: "../Pages/Portals/PortalTopDivider.png");
              }

              Group #TabScroll {
                LayoutMode: TopScrolling;
                Anchor: (Full: 1);
                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                Group {
                  LayoutMode: Top;
                  Anchor: (Full: 1);

                  // ===================== OVERVIEW =====================
                  Group #TabOverviewPanel {
                    LayoutMode: Top;
                    Anchor: (Full: 1);
                    Visible: true;

                    Label #OverviewHeader {
                      Text: "OVERVIEW";
                      Anchor: (Height: 18, Bottom: 10);
                      Style: @SectionTitle;
                    }

                    Label #OverviewLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #OverviewLine1 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #OverviewLine2 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #OverviewLine3 { Text: ""; Anchor: (Height: 20, Bottom: 10); Style: @BodyLineMuted; }

                    Label #OverviewHintsHeader {
                      Text: "HINTS";
                      Anchor: (Height: 18, Bottom: 8);
                      Style: @SectionTitle;
                    }

                    Label #OverviewHint0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #OverviewHint1 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #OverviewHint2 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                  }

                  // ===================== INTEGRATIONS =====================
                  Group #TabIntegrationsPanel {
                    LayoutMode: Top;
                    Anchor: (Full: 1);
                    Visible: false;

                    Label #IntegrationsHeader {
                      Text: "INTEGRATIONS";
                      Anchor: (Height: 18, Bottom: 10);
                      Style: @SectionTitle;
                    }

                    Label #IntegrationsIntro0 {
                      Text: "";
                      Anchor: (Height: 22);
                      Style: @BodyLineMuted;
                    }

                    Label #IntegrationsIntro1 {
                      Text: "";
                      Anchor: (Height: 22, Bottom: 12);
                      Style: @BodyLineMuted;
                    }

                    Group #IntegrationCardsRow0 {
                      LayoutMode: Left;
                      Anchor: (Height: 96, Bottom: 10);

                      Group #PermissionsCard {
                        FlexWeight: 1;
                        Anchor: (Height: 90, Right: 10);
                        Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
                        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
                        LayoutMode: Top;

                        Label #PermissionsCardTitle {
                          Text: "PERMISSIONS";
                          Anchor: (Height: 18, Bottom: 6);
                          Style: @SectionTitle;
                        }

                        Label #PermissionsCardStatus {
                          Text: "Active: Native";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }

                        Label #PermissionsCardMeta {
                          Text: "LuckPerms: No | HyperPerms: No";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }
                      }

                      Group #PrefixesCard {
                        FlexWeight: 1;
                        Anchor: (Height: 90, Right: 10);
                        Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
                        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
                        LayoutMode: Top;

                        Label #PrefixesCardTitle {
                          Text: "PREFIXES";
                          Anchor: (Height: 18, Bottom: 6);
                          Style: @SectionTitle;
                        }

                        Label #PrefixesCardStatus {
                          Text: "Provider: None";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }

                        Label #PrefixesCardMeta {
                          Text: "Fallback chain available";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }
                      }

                      Group #EconomyCard {
                        FlexWeight: 1;
                        Anchor: (Height: 90);
                        Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
                        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
                        LayoutMode: Top;

                        Label #EconomyCardTitle {
                          Text: "ECONOMY";
                          Anchor: (Height: 18, Bottom: 6);
                          Style: @SectionTitle;
                        }

                        Label #EconomyCardStatus {
                          Text: "Mode: NONE";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }

                        Label #EconomyCardMeta {
                          Text: "Backends: none";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }
                      }
                    }

                    Group #IntegrationCardsRow1 {
                      LayoutMode: Left;
                      Anchor: (Height: 96, Bottom: 12);

                      Group #PlaytimeCard {
                        FlexWeight: 1;
                        Anchor: (Height: 90, Right: 10);
                        Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
                        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
                        LayoutMode: Top;

                        Label #PlaytimeCardTitle {
                          Text: "PLAYTIME";
                          Anchor: (Height: 18, Bottom: 6);
                          Style: @SectionTitle;
                        }

                        Label #PlaytimeCardStatus {
                          Text: "Provider: Internal";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }

                        Label #PlaytimeCardMeta {
                          Text: "Stats: No | Items: No";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }
                      }

                      Group #PlaceholdersCard {
                        FlexWeight: 1;
                        Anchor: (Height: 90, Right: 10);
                        Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
                        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
                        LayoutMode: Top;

                        Label #PlaceholdersCardTitle {
                          Text: "PLACEHOLDERS";
                          Anchor: (Height: 18, Bottom: 6);
                          Style: @SectionTitle;
                        }

                        Label #PlaceholdersCardStatus {
                          Text: "WiFlow: No";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }

                        Label #PlaceholdersCardMeta {
                          Text: "Helpch: No";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }
                      }

                      Group #NameplateCard {
                        FlexWeight: 1;
                        Anchor: (Height: 90);
                        Background: (TexturePath: "../Common/ContainerFullPatch.png", Border: 23);
                        Padding: (Top: 10, Bottom: 10, Left: 12, Right: 12);
                        LayoutMode: Top;

                        Label #NameplateCardTitle {
                          Text: "NAMEPLATES";
                          Anchor: (Height: 18, Bottom: 6);
                          Style: @SectionTitle;
                        }

                        Label #NameplateCardStatus {
                          Text: "EndlessLeveling: No";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }

                        Label #NameplateCardMeta {
                          Text: "Standard rendering active";
                          Anchor: (Height: 20);
                          Style: @BodyLineMuted;
                        }
                      }
                    }

                    Group {
                      Anchor: (Height: 1, Bottom: 12);
                      Background: (Color: #2b3542);
                    }

                    Label #PermissionsSectionHeader {
                      Text: "PERMISSION BACKENDS";
                      Anchor: (Height: 18, Bottom: 8);
                      Style: @SectionTitle;
                    }

                    Label #PermissionsLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PermissionsLine1 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PermissionsLine2 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PermissionsLine3 {
                      Text: "";
                      Anchor: (Height: 32, Bottom: 12);
                      Style: (FontSize: 12, TextColor: #96a9be, Wrap: true);
                    }

                    Group {
                      Anchor: (Height: 1, Bottom: 12);
                      Background: (Color: #2b3542);
                    }

                    Label #PrefixSectionHeader {
                      Text: "PREFIX PROVIDERS";
                      Anchor: (Height: 18, Bottom: 8);
                      Style: @SectionTitle;
                    }

                    Label #PrefixLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PrefixLine1 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PrefixLine2 { Text: ""; Anchor: (Height: 20, Bottom: 12); Style: @BodyLineMuted; }

                    Group {
                      Anchor: (Height: 1, Bottom: 12);
                      Background: (Color: #2b3542);
                    }

                    Label #EconomySectionHeader {
                      Text: "ECONOMY BACKENDS";
                      Anchor: (Height: 18, Bottom: 8);
                      Style: @SectionTitle;
                    }

                    Label #EconomyLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #EconomyLine1 {
                      Text: "";
                      Anchor: (Height: 32);
                      Style: (FontSize: 12, TextColor: #96a9be, Wrap: true);
                    }
                    Label #EconomyLine2 {
                      Text: "";
                      Anchor: (Height: 32);
                      Style: (FontSize: 12, TextColor: #96a9be, Wrap: true);
                    }
                    Label #EconomyLine3 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #EconomyLine4 { Text: ""; Anchor: (Height: 20, Bottom: 12); Style: @BodyLineMuted; }

                    Group {
                      Anchor: (Height: 1, Bottom: 12);
                      Background: (Color: #2b3542);
                    }

                    Label #PlaytimeSectionHeader {
                      Text: "PLAYTIME / STATS / ITEMS";
                      Anchor: (Height: 18, Bottom: 8);
                      Style: @SectionTitle;
                    }

                    Label #PlaytimeLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PlaytimeLine1 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PlaytimeLine2 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PlaytimeLine3 { Text: ""; Anchor: (Height: 20, Bottom: 12); Style: @BodyLineMuted; }

                    Group {
                      Anchor: (Height: 1, Bottom: 12);
                      Background: (Color: #2b3542);
                    }

                    Label #PlaceholderSectionHeader {
                      Text: "PLACEHOLDERS";
                      Anchor: (Height: 18, Bottom: 8);
                      Style: @SectionTitle;
                    }

                    Label #PlaceholderLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PlaceholderLine1 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #PlaceholderLine2 { Text: ""; Anchor: (Height: 20, Bottom: 12); Style: @BodyLineMuted; }

                    Group {
                      Anchor: (Height: 1, Bottom: 12);
                      Background: (Color: #2b3542);
                    }

                    Label #NameplateSectionHeader {
                      Text: "NAMEPLATE EXTENSIONS";
                      Anchor: (Height: 18, Bottom: 8);
                      Style: @SectionTitle;
                    }

                    Label #NameplateLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #NameplateLine1 {
                      Text: "";
                      Anchor: (Height: 32);
                      Style: (FontSize: 12, TextColor: #96a9be, Wrap: true);
                    }
                    Label #NameplateLine2 { Text: ""; Anchor: (Height: 20, Bottom: 12); Style: @BodyLineMuted; }

                    Group {
                      Anchor: (Height: 1, Bottom: 12);
                      Background: (Color: #2b3542);
                    }

                    Label #NotesSectionHeader {
                      Text: "NOTES";
                      Anchor: (Height: 18, Bottom: 8);
                      Style: @SectionTitle;
                    }

                    Label #NotesLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #NotesLine1 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #NotesLine2 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #NotesLine3 {
                      Text: "";
                      Anchor: (Height: 32);
                      Style: (FontSize: 12, TextColor: #96a9be, Wrap: true);
                    }
                    Label #NotesLine4 {
                      Text: "";
                      Anchor: (Height: 32);
                      Style: (FontSize: 12, TextColor: #96a9be, Wrap: true);
                    }
                  }

                  // ===================== DEBUG =====================
                  Group #TabDebugPanel {
                    LayoutMode: Top;
                    Anchor: (Full: 1);
                    Visible: false;

                    Label #DebugHeader {
                      Text: "DEBUG & SUPPORT";
                      Anchor: (Height: 18, Bottom: 10);
                      Style: @SectionTitle;
                    }

                    Label #DebugLine0 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #DebugLine1 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #DebugLine2 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #DebugLine3 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #DebugLine4 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #DebugLine5 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                    Label #DebugLine6 { Text: ""; Anchor: (Height: 20); Style: @BodyLineMuted; }
                  }

                  // ===================== SUPPORT =====================
                  Group #TabSupportPanel {
                    LayoutMode: Top;
                    Anchor: (Full: 1);
                    Visible: false;

                    Label #SupportHeader {
                      Text: "SUPPORT";
                      Anchor: (Height: 18, Bottom: 10);
                      Style: @SectionTitle;
                    }

                    Label #SupportLine0 {
                      Text: "Need help? Use the mod page, bug report button, or your support channels.";
                      Anchor: (Height: 22);
                      Style: @BodyLineMuted;
                    }

                    Label #SupportLine1 {
                      Text: "Attach debug snapshots and relevant server logs when reporting issues.";
                      Anchor: (Height: 22);
                      Style: @BodyLineMuted;
                    }
                  }
                }
              }
            }

            Group { Anchor: (Height: 12); }

            Group {
              LayoutMode: Left;
              Anchor: (Height: 44);

              Group { FlexWeight: 1; }

              TextButton #CloseButton {
                Text: "Close";
                Anchor: (Width: 110, Height: 40);
                Style: @SecondaryButton;
              }
            }
          }
        }
      }

      // ===================== FOOTER =====================
      Group {
        Anchor: (Height: 28, Left: 0, Right: 0);
        LayoutMode: Middle;

        Label #FooterCloseHint {
          Style: (FontSize: 11, TextColor: #6e7681, HorizontalAlignment: Center, VerticalAlignment: Center);
          Text: "Press ESC to close";
        }
      }
    }
  }
}